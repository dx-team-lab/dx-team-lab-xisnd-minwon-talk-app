rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MINWON COMMUNITY - SECURITY RULES PHILOSOPHY
     *
     * Core Philosophy: 
     * This ruleset implements a robust, performant authorization model designed for high-scale 
     * civil complaint management. It prioritizes "Authorization Independence" by using 
     * denormalization and dedicated role collections (DBAC) to avoid expensive cross-document 
     * lookups (get() calls) during rule evaluation.
     *
     * Data Structure:
     * - /users/{userId}: Private user profiles.
     * - /roles_admin, /roles_manager: Database-wide role flags via document existence.
     * - /projects/{projectId}: Collaborative containers for complaints.
     * - /projects/{projectId}/complaints/{complaintId}: Project-scoped complaints with 
     *   denormalized project ownership data.
     * - /cases, /response_plans: Global reference data for all authenticated users.
     *
     * Key Security Decisions:
     * 1. DBAC Pattern: Admin and Manager roles are determined by the existence of a 
     *    document in specific top-level collections, enabling fast 'exists()' checks.
     * 2. Denormalization for Performance: Complaints contain copies of 'projectMemberIds' 
     *    and 'projectOwnerId' to allow atomic authorization without reading the parent project.
     * 3. Prototyping Flexibility: Rules enforce strict identity and relationship 
     *    integrity (who owns what) but remain agnostic to specific data types and 
     *    content schemas to allow for rapid UI/UX iteration.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid));
    }

    function isProjectMember(memberIds) {
      return isSignedIn() && request.auth.uid in memberIds;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for user profile documents. Restricted to the individual user or admins.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 
      allow create: if isOwner(userId);
      allow update: if (isExistingOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description DBAC flag for administrators.
     */
    match /roles_admin/{adminId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description DBAC flag for managers. Managed by administrators.
     */
    match /roles_manager/{managerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Construction projects shared among specific members.
     */
    match /projects/{projectId} {
      allow get, list: if isSignedIn() && (isProjectMember(resource.data.memberIds) || isAdmin());
      allow create: if isSignedIn();
      allow update: if resource != null && (isProjectMember(resource.data.memberIds) || isAdmin());
      allow delete: if resource != null && isAdmin();
    }

    /**
     * @description Complaints filed against specific projects.
     */
    match /projects/{projectId}/complaints/{complaintId} {
      allow get, list: if isSignedIn() && (isProjectMember(resource.data.projectMemberIds) || resource.data.createdBy == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if resource != null && (resource.data.createdBy == request.auth.uid || isAdmin() || isManager());
      allow delete: if resource != null && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    /**
     * @description Global compensation cases and precedents.
     */
    match /cases/{caseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isManager();
    }

    /**
     * @description Official guidelines for responding to complaints.
     */
    match /response_plans/{responsePlanId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}